# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_token_here

# Comma-separated list of Discord Channel IDs for storage
STORAGE_CHANNELS=channel_id_1,channel_id_2

# 32-character string for AES-256 encryption
ENCRYPTION_KEY=your_32_char_key_here_0000000000

# Server Port
PORT=3000

# MongoDB Connection URI (optional, if using MongoDB for metadata storage)
MONGO_URI=mongodb://localhost:27017/discord-s3